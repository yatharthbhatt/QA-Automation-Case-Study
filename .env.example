# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# --- Target environment ---
# Base app URL. Tenant subdomain is applied by the framework (see data/tenants.json).
BASE_URL=https://app.workflowpro.com
API_BASE_URL=https://api.workflowpro.com

# --- Test credentials (per role). In real CI these come from a secrets manager. ---
ADMIN_EMAIL=admin@company1.com
ADMIN_PASSWORD=changeme
MANAGER_EMAIL=manager@company1.com
MANAGER_PASSWORD=changeme
EMPLOYEE_EMAIL=employee@company1.com
EMPLOYEE_PASSWORD=changeme

# --- API auth ---
# If the platform issues service tokens, put one here to skip UI login for API setup.
API_TOKEN=

# --- 2FA (test accounts) ---
# Shared TOTP secret for automation-only accounts so 2FA can be solved deterministically.
# See docs/PART1_FLAKY_TEST_ANALYSIS.md.
TOTP_SECRET=

# --- BrowserStack ---
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=

# --- Execution ---
HEADLESS=true
DEFAULT_TIMEOUT_MS=15000
